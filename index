<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#000000" />
  <title>QR Scanner PWA</title>
  <style>
    * { box-sizing:border-box; margin:0; padding:0; }

    body {
      font-family:'Sarabun', 'Prompt', Arial, sans-serif;
      background:#0f172a;
      color:#f1f5f9;
      height:100dvh;
      display:flex;
      flex-direction:column;
      align-items:center;
      justify-content:center;
      overflow:hidden;
      user-select:none;
    }

    h2 {
      font-size:17px;
      font-weight:700;
      color:#f1f5f9;
      margin-bottom:16px;
      letter-spacing:0.3px;
    }

    #app {
      width:100%;
      max-width:420px;
      padding:20px 16px;
      display:flex;
      flex-direction:column;
      align-items:center;
    }

    /* VIDEO WRAP */
    #video-wrap {
      position:relative;
      width:100%;
      aspect-ratio:1;
      background:#020617;
      border-radius:20px;
      overflow:hidden;
      display:flex;
      align-items:center;
      justify-content:center;
      box-shadow:0 8px 32px rgba(0,0,0,0.5);
    }

    #qr-video {
      width:100%;
      height:100%;
      object-fit:cover;
      display:none;
    }

    #placeholder {
      text-align:center;
      color:rgba(255,255,255,0.35);
      font-size:13px;
    }

    #placeholder .icon { font-size:52px; display:block; margin-bottom:10px; }

    /* CORNERS */
    .corner {
      position:absolute;
      width:32px;
      height:32px;
      border-color:#f59e0b;
      border-style:solid;
      pointer-events:none;
      z-index:10;
    }
    .corner.tl { top:12px; left:12px; border-width:3px 0 0 3px; border-radius:5px 0 0 0; }
    .corner.tr { top:12px; right:12px; border-width:3px 3px 0 0; border-radius:0 5px 0 0; }
    .corner.bl { bottom:12px; left:12px; border-width:0 0 3px 3px; border-radius:0 0 0 5px; }
    .corner.br { bottom:12px; right:12px; border-width:0 3px 3px 0; border-radius:0 0 5px 0; }

    /* SCAN LINE */
    #scanline {
      display:none;
      position:absolute;
      left:12px; right:12px;
      height:2px;
      background:linear-gradient(90deg, transparent, #f59e0b, transparent);
      border-radius:2px;
      animation:sweep 2s ease-in-out infinite;
      z-index:10;
    }
    @keyframes sweep { 0%,100%{ top:14%; } 50%{ top:82%; } }

    canvas { display:none; }

    /* STATUS */
    #status {
      margin-top:14px;
      font-size:14px;
      color:#94a3b8;
      text-align:center;
      min-height:20px;
      line-height:1.5;
    }

    /* RESULT */
    #result-badge {
      display:none;
      margin-top:12px;
      background:#dcfce7;
      color:#15803d;
      border-radius:14px;
      padding:12px 20px;
      font-size:15px;
      font-weight:700;
      text-align:center;
      width:100%;
      animation:popIn 0.25s ease;
    }
    @keyframes popIn { from{transform:scale(0.85);opacity:0} to{transform:scale(1);opacity:1} }

    /* BUTTONS */
    .btn {
      margin-top:12px;
      width:100%;
      padding:14px;
      border:none;
      border-radius:14px;
      font-family:'Sarabun',Arial,sans-serif;
      font-size:15px;
      font-weight:700;
      cursor:pointer;
      transition:transform 0.15s, opacity 0.15s;
    }
    .btn:active { transform:scale(0.97); }

    .btn-primary {
      background:linear-gradient(135deg,#2563eb,#1d4ed8);
      color:#fff;
      box-shadow:0 4px 14px rgba(37,99,235,0.4);
    }

    .btn-secondary {
      background:#1e293b;
      color:#94a3b8;
    }

    /* ERROR GUIDE */
    #error-guide {
      display:none;
      margin-top:14px;
      background:#1e293b;
      border:1.5px solid #f59e0b;
      border-radius:16px;
      padding:14px 16px;
      width:100%;
      font-size:13px;
      color:#fde68a;
      line-height:2;
    }
    #error-guide .title {
      font-size:14px;
      font-weight:700;
      color:#f59e0b;
      margin-bottom:8px;
    }
  </style>
</head>
<body>
<div id="app">
  <h2>📷 สแกน QR ทะเบียนเครื่อง</h2>

  <div id="video-wrap">
    <div id="placeholder">
      <span class="icon">📷</span>
      กดปุ่มด้านล่างเพื่อเปิดกล้อง
    </div>
    <video id="qr-video" autoplay playsinline muted></video>
    <canvas id="qr-canvas"></canvas>
    <div class="corner tl"></div>
    <div class="corner tr"></div>
    <div class="corner bl"></div>
    <div class="corner br"></div>
    <div id="scanline"></div>
  </div>

  <div id="status">กดปุ่มเปิดกล้องแล้วชี้ไปที่ QR Code</div>
  <div id="result-badge"></div>

  <!-- Error guide -->
  <div id="error-guide">
    <div class="title">🔒 Chrome บล็อกกล้อง — วิธีแก้:</div>
    <div>① กดไอคอน 🔒 ที่แถบ URL ด้านบน</div>
    <div>② เลือก <b>Site settings / การตั้งค่าไซต์</b></div>
    <div>③ หา <b>Camera</b> → เปลี่ยนเป็น <b>Allow ✅</b></div>
    <div>④ Reload หน้าแล้วลองใหม่</div>
  </div>

  <button class="btn btn-primary" id="btn-start" onclick="startCamera()">📷 เปิดกล้อง</button>
  <button class="btn btn-secondary" onclick="closeWindow()">✕ ปิดหน้าต่าง</button>
</div>

<script src="https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.min.js"></script>
<script>
  var stream = null;
  var animFrame = null;
  var found = false;

  // --- รับ origin ของ opener เพื่อใช้ postMessage ---
  // Google Apps Script มี origin แบบ https://script.google.com
  // แต่อาจ embed ใน iframe จึงส่ง * ไปก่อน แล้วกรองฝั่ง GAS เอง
  var TARGET_ORIGIN = "*";

  function setStatus(msg) {
    document.getElementById("status").textContent = msg;
  }

  function startCamera() {
    if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
      setStatus("⚠️ เบราว์เซอร์ไม่รองรับ Camera API (ต้องใช้ HTTPS)");
      return;
    }
    document.getElementById("btn-start").disabled = true;
    document.getElementById("error-guide").style.display = "none";
    setStatus("กำลังขอสิทธิ์กล้อง...");

    navigator.mediaDevices.getUserMedia({
      video: { facingMode: { ideal: "environment" }, width: { ideal: 1280 }, height: { ideal: 720 } }
    }).then(function(s) {
      stream = s;
      var vid = document.getElementById("qr-video");
      vid.srcObject = stream;
      vid.style.display = "block";
      document.getElementById("placeholder").style.display = "none";
      document.getElementById("scanline").style.display = "block";
      setStatus("ชี้กล้องไปที่ QR Code ของเครื่องจักร...");
      vid.addEventListener("loadedmetadata", scanLoop);
    }).catch(function(e) {
      document.getElementById("btn-start").disabled = false;
      if (e.name === "NotAllowedError" || e.name === "PermissionDeniedError") {
        document.getElementById("placeholder").innerHTML = '<span class="icon">🚫</span>ถูกบล็อกการใช้กล้อง';
        document.getElementById("error-guide").style.display = "block";
        setStatus("");
      } else if (e.name === "NotFoundError") {
        setStatus("⚠️ ไม่พบกล้องในอุปกรณ์นี้");
      } else if (e.name === "NotReadableError") {
        setStatus("⚠️ กล้องถูกใช้งานโดยแอปอื่นอยู่");
      } else {
        setStatus("⚠️ เปิดกล้องไม่ได้: " + e.message);
      }
    });
  }

  function scanLoop() {
    var vid    = document.getElementById("qr-video");
    var canvas = document.getElementById("qr-canvas");
    var ctx    = canvas.getContext("2d");

    function loop() {
      if (!stream || found) return;
      if (vid.readyState === vid.HAVE_ENOUGH_DATA) {
        canvas.width  = vid.videoWidth;
        canvas.height = vid.videoHeight;
        ctx.drawImage(vid, 0, 0, canvas.width, canvas.height);
        var imgData = ctx.getImageData(0, 0, canvas.width, canvas.height);
        var code = jsQR(imgData.data, imgData.width, imgData.height, { inversionAttempts: "dontInvert" });
        if (code && code.data) {
          found = true;
          onFound(code.data);
          return;
        }
      }
      animFrame = requestAnimationFrame(loop);
    }
    animFrame = requestAnimationFrame(loop);
  }

  function onFound(raw) {
    // ดึง field แรก (ทะเบียนเครื่อง) กรณี QR มีหลาย field คั่นด้วย | , : tab newline
    var machineNo = raw.split(/[|,:\t\n]/)[0].trim();

    // หยุดกล้อง
    stopCamera();
    document.getElementById("scanline").style.display = "none";

    // แสดงผล
    setStatus("✅ พบ QR Code!");
    var badge = document.getElementById("result-badge");
    badge.textContent = "🔩 ทะเบียนเครื่อง: " + machineNo;
    badge.style.display = "block";

    // ส่งค่ากลับหน้าแม่ (GAS) ผ่าน postMessage
    if (window.opener && !window.opener.closed) {
      window.opener.postMessage({ machineNo: machineNo }, TARGET_ORIGIN);
    }

    // ปิดหน้าต่างนี้หลัง 1.2 วินาที
    setTimeout(function() { window.close(); }, 1200);
  }

  function stopCamera() {
    if (animFrame) { cancelAnimationFrame(animFrame); animFrame = null; }
    if (stream)    { stream.getTracks().forEach(function(t){ t.stop(); }); stream = null; }
  }

  function closeWindow() {
    stopCamera();
    window.close();
  }
</script>
</body>
</html>
